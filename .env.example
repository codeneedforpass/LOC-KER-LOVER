# =============================================================================
# Loc-Ker Lover — standalone environment (no Google AI Studio)
# =============================================================================
# Copy to `.env.local` for local dev. On Render/Vercel/Netlify, set the same
# keys in the host dashboard. Only `VITE_*` vars are exposed to the browser.
# =============================================================================

# --- App ---------------------------------------------------------------------
# Public URL of your deployed app (OAuth redirects, share links, CORS).
VITE_APP_URL=http://localhost:3000

# development | staging | production
VITE_APP_ENV=development

# Set to "true" to keep mock in-memory data (current simulator). Set to "false"
# when Supabase is configured and you are wiring real backend calls.
VITE_USE_MOCK_DATA=true

# --- Supabase (backend: database, auth, realtime, storage) -------------------
# Free tier: https://supabase.com/dashboard — create a project (skip GitHub link),
# then run supabase/schema.reference.sql in the SQL Editor. Copy keys from
# Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# NEVER put service_role in the frontend. Use only in Edge Functions or a
# private server if you add one later:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth (pick ONE approach) ------------------------------------------------
# Option A — Supabase Auth (recommended: same vendor as DB/realtime)
# Configure email/OAuth in Supabase Dashboard → Authentication.
# No extra keys needed beyond VITE_SUPABASE_* above.

# Option B — Clerk (auth for the app shell; links to Supabase profiles via clerk_id)
# Dashboard → API Keys → Publishable key
# App: app_3FGuAAJPDSrZ89ctFuyPYH9SbuN
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- Maps (OpenStreetMap + Leaflet — no key required) -------------------------
# The map uses OSM tiles by default. Mapbox is optional if you switch tile layers later.
# VITE_MAPBOX_TOKEN=pk.eyJ...

# --- Push notifications (OneSignal) ------------------------------------------
# Free tier: https://onesignal.com — create a Web app, copy App ID.
# Dashboard → Settings → Keys & IDs → OneSignal App ID
# Site URL must match VITE_APP_URL (localhost OK for dev with allowLocalhostAsSecureOrigin).
VITE_ONESIGNAL_APP_ID=c5903d6c-9801-4083-80bf-f3b48b41f9dc
